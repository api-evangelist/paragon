  "info": {
    "_postman_id": "3cb7821e-690d-48a8-8f5a-40023ddb8327",
    "name": "Paragon Task History API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Task History API allows you to query your users' usage of integration workflows and access data from historical workflow executions. The Task History API can be used to analyze integration usage or pull information about historical workflow executions into your application. Available for Paragon customers on Enterprise plans. Rate limited to 1,000 requests per 10 minutes.\n\nContact Support:\n Name: Paragon",
      "type": "text/plain"
    }
  }
