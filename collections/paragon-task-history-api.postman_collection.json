        {
          "id": "dea617cc-f22c-4160-a54b-9acc080b5277",
          "name": "Paragon Get workflow executions",
          "request": {
            "name": "Paragon Get workflow executions",
            "description": {
              "content": "Search through historical workflow executions with filtering options. Returns paginated results with up to 100 records per page. If additional pages are available, the response will include a nextLink URL to retrieve the next page.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "projects",
                ":projectId",
                "task-history",
                "workflow-executions"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "integration",
                  "value": "<string>",
                  "description": "Filter by integration name (e.g., salesforce, hubspot)."
                },
                {
                  "disabled": false,
                  "key": "workflowId",
                  "value": "<string>",
                  "description": "Filter by workflow ID."
                },
                {
                  "disabled": false,
                  "key": "userId",
                  "value": "<string>",
                  "description": "Filter by Connected User ID."
                },
                {
                  "disabled": false,
                  "key": "status",
                  "value": "<string>",
                  "description": "Filter by execution status."
                },
                {
                  "disabled": false,
                  "key": "afterDate",
                  "value": "<dateTime>",
                  "description": "Filter executions that started after this date (ISO 8601 format)."
                },
                {
                  "disabled": false,
                  "key": "beforeDate",
                  "value": "<dateTime>",
                  "description": "Filter executions that started before this date (ISO 8601 format)."
                },
                {
                  "disabled": false,
                  "key": "sortBy",
                  "value": "<string>",
                  "description": "Sort order for the results."
                },
                {
                  "disabled": false,
                  "key": "offset",
                  "value": "<integer>",
                  "description": "Pagination offset for retrieving additional pages."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "projectId",
                  "description": "(Required) Your Paragon Project ID."
                }
              ]
            },
            "header": [
