    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Triggers API (Beta) lets you subscribe to events from your users' integrations using Paragon's catalog of pre-built triggers across 130+ SaaS applications, or custom webhooks. Use it to give your app or AI agent real-time visibility into third-party events such as `Slack: Message Received`, `Google Calendar: New Event`, or `Salesforce: Record Updated`. Subscriptions are scoped per Connected User via Paragon User Token (JWT).\n\nContact Support:\n Name: Paragon",
      "type": "text/plain"
    }
